# 네이밍: {environment}-{name_domain}-{name_service}-{역할}
# 예: stg-news-metaj-was01, stg-news-metaj-bastion01

# --- 환경 ---
environment  = "stg"
name_domain  = "news"
name_service = "metaj"
project_name = "jtbc"

# --- 네트워크 ---
vpc_cidr            = "10.10.2.0/24"
public_subnet_cidr  = ["10.10.2.0/27", "10.10.2.32/27"]
private_subnet_cidr = ["10.10.2.64/26", "10.10.2.128/26"]
db_subnet_cidr      = ["10.10.2.192/27", "10.10.2.224/27"]

# --- EC2 ---
ec2_instance_type  = "t3.medium"
ec2_instance_count = 1
ec2_key_name       = "stg-news-metaj-key"
ec2_ebs_size_gb    = 30

# --- Bastion ---
bastion_instance_type           = "t3.micro"
bastion_key_name                = "stg-news-metaj-key"
bastion_ebs_size_gb             = 10
bastion_ssh_allowed_cidr_blocks = ["JTBC_사내망_IP/32"]

# --- ALB / WAF ---
alb_listener_port     = 80   # HTTPS:443 전환 시 acm_certificate_arn 추가 필요
target_port           = 8080
health_check_path     = "/health"
waf_allowed_ipv4_cidr = ["JTBC_사내망_IP/32"]

# --- RDS ---
rds_instance_class = "db.t3.medium"
rds_multi_az       = false
rds_storage_gb     = 50
# rds_db_name은 null이 기본값 — 개발자가 Bastion에서 직접 DB 생성
# rds_db_name = "DB_METAJ"
rds_username       = "jtbc"
# rds_password는 환경변수로 주입 권장:
#   export TF_VAR_rds_password="your_password"
