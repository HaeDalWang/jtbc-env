# 네이밍: {environment}-{name_domain}-{name_service}-{역할}
# 예: prd-news-metaj-was-01, prd-news-metaj-bastion

# --- 환경 ---
environment  = "prd"
name_domain  = "news"
name_service = "metaj"
project_name = "jtbc"

# --- 네트워크 ---
vpc_cidr            = "10.10.1.0/24"
public_subnet_cidr  = ["10.10.1.0/27", "10.10.1.32/27"]
private_subnet_cidr = ["10.10.1.64/26", "10.10.1.128/26"]
db_subnet_cidr      = ["10.10.1.192/27", "10.10.1.224/27"]

# --- EC2 ---
ec2_instance_type  = "t3.large"
ec2_instance_count = 2
ec2_key_name       = "prd-news-metaj-key"
ec2_ebs_size_gb    = 30

# --- Bastion ---
bastion_instance_type           = "t3.micro"
bastion_key_name                = "prd-news-metaj-key"
bastion_ebs_size_gb             = 10
bastion_ssh_allowed_cidr_blocks = ["JTBC_사내망_IP/32"]

# --- ALB / WAF ---
alb_listener_port     = 80
target_port           = 8080
health_check_path     = "/actuator/health"
waf_allowed_ipv4_cidr = ["JTBC_사내망_IP/32"]

# --- RDS ---
rds_instance_class = "db.t3.large"
rds_multi_az       = true
rds_storage_gb     = 50
# rds_db_name은 null이 기본값 — 개발자가 Bastion에서 직접 DB 생성
# rds_db_name = "DB_METAJ"
rds_username       = "jtbc"
# rds_password는 환경변수로 주입 권장:
#   export TF_VAR_rds_password="your_password"
